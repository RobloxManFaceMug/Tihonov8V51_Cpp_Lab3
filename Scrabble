#include <vector>
#include <string>
#include <algorithm>

int ScrabbleScore(std::vector<std::string> input) {
    int total = 0;
    std::vector<std::string> letters = {"a","b","c","d","e","f","g","h","i","j","k","l","m","n","o","p","q","r","s","t","u","v","w","x","y","z"};
    std::vector<int> score = {1,3,3,2,1,4,2,4,1,8,5,1,3,1,1,3,10,1,1,1,1,4,4,8,4,10};
    std::string NewString = "";
    for (int i = 0; i < input.size(); i++) {
        NewString += input.at(i);
    }
    char CurrLetter;
    for (int i = 0; i < 26; i++) {
        CurrLetter = letters.at(i)[0];
        total += (count(NewString.begin(), NewString.end(), CurrLetter))*score.at(i);
    }
    return total;
}